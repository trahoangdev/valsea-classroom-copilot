# Backend only — never expose to the browser bundle
VALSEA_API_KEY=
LLM_API_KEY=

# Optional LLM (OpenAI-compatible)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Supabase (Phase 5 — server uses service role only; run server/supabase/migrations/001_classroom_copilot.sql in SQL Editor)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Realtime gateway (browser uses NEXT_PUBLIC_WS_URL)
PORT=3001

# Browser → gateway (Next.js public — URL only, never secrets)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
